---
export const prerender = true;

import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import TableOfContents from "../../../components/TableOfContents.astro";
import { site } from "../../../config/site";

export async function getStaticPaths() {
  const stories = await getCollection("stories");
  return stories.map((story) => ({
    params: { lang: story.data.lang, id: story.data.story_slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { lang, id } = Astro.params;
const { Content, headings } = await render(story);
const description = `${story.data.title} — ${story.data.record_count} records from ${story.data.date_range}. An editorial narrative by ${site.bepely.name}, powered by ${site.narr.name}.`;
---

<BaseLayout title={`${story.data.title} — ${site.title}`} description={description} lang={lang} currentPath={`stories/${id}/`} pageType="story">
  <article>
    <header class="story-header">
      <h1 class="story-title">{story.data.title}</h1>
      <div class="story-meta">
        <span class="date-range">{story.data.date_range}</span>
        <span class="meta-sep">&middot;</span>
        <span class="record-count">{story.data.record_count} records</span>
      </div>
    </header>
    <TableOfContents headings={headings} />
    <Content />
  </article>
</BaseLayout>

<style>
  .story-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .story-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .story-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .meta-sep {
    color: var(--color-border);
  }

  article {
    line-height: 1.8;
  }
</style>
