---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "ru" } },
    { params: { lang: "pt" } },
  ];
}

const { lang } = Astro.params;

const allStories = await getCollection("stories");
const stories = allStories
  .filter((s) => s.data.lang === lang)
  .sort((a, b) => b.data.date_range.localeCompare(a.data.date_range));
---

<BaseLayout title="Bree's Blog" lang={lang}>
  <section class="hero">
    <h1 class="hero-name">Bree's Blog</h1>
    <p class="hero-tagline">Adventures, thoughts, and daily chaos — illustrated by AI.</p>
    <p class="hero-narr">A <span class="narr-accent">Narr</span> production</p>
  </section>

  <section class="stories">
    {stories.length === 0 ? (
      <p class="empty">No stories published yet.</p>
    ) : (
      <div class="story-list">
        {stories.map((s) => (
          <a href={`/${lang}/stories/${s.data.story_slug}/`} class="story-card">
            <h2 class="story-title">{s.data.title}</h2>
            <div class="story-meta">
              <span class="story-date">{s.data.date_range}</span>
              <span class="story-records">{s.data.record_count} records</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero-name {
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #f5c542, #e8752a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    color: #a09880;
    font-size: 1.1rem;
  }

  .hero-narr {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #a09880;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .narr-accent {
    font-weight: 700;
    background: linear-gradient(135deg, #f5c542, #e8752a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stories {
    margin-top: 1rem;
  }

  .empty {
    color: #a09880;
    font-style: italic;
    text-align: center;
    margin-top: 2rem;
  }

  .story-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .story-card {
    display: block;
    padding: 1.25rem;
    background: #141410;
    border: 1px solid #2a2518;
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .story-card:hover {
    border-color: #f5c542;
    box-shadow: 0 2px 12px rgba(245, 197, 66, 0.1);
    text-decoration: none;
  }

  .story-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f0ece4;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .story-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: #a09880;
  }
</style>
