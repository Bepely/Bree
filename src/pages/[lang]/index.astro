---
export const prerender = true;

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NarrLink from "../../components/NarrLink.astro";
import StoryCard from "../../components/StoryCard.astro";
import { langCodes } from "../../config/languages";
import { site } from "../../config/site";

export function getStaticPaths() {
  return langCodes.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const allStories = await getCollection("stories");
const stories = allStories
  .filter((s) => s.data.lang === lang)
  .sort((a, b) => b.data.date_range.localeCompare(a.data.date_range));
---

<BaseLayout title={site.title} lang={lang} pageType="home">
  <section class="hero">
    <h1 class="hero-name">{site.title}</h1>
    <p class="hero-tagline">Raw captures turned into editorial narratives — powered by AI.</p>
    <p class="hero-sub">A <NarrLink /> production</p>
  </section>

  <section class="stories">
    {stories.length === 0 ? (
      <p class="empty">No stories yet — but something's coming soon.</p>
    ) : (
      <div class="story-list">
        {stories.map((s) => (
          <StoryCard
            lang={lang}
            slug={s.data.story_slug}
            title={s.data.title}
            dateRange={s.data.date_range}
            recordCount={s.data.record_count}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .hero-name {
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-sm);
  }

  .hero-tagline {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .hero-sub {
    margin-top: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .stories {
    margin-top: var(--space-md);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    margin-top: var(--space-xl);
  }

  .story-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
