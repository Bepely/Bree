---
import LangSwitcher from "../components/LangSwitcher.astro";

interface Props {
  title?: string;
  lang?: string;
  currentPath?: string;
}

const { title = "Bree's Blog", lang = "en", currentPath = "" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <a href={`/${lang}/`} class="site-title">Bree's Blog</a>
      <LangSwitcher currentLang={lang} currentPath={currentPath} />
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-links">
        <a href="https://github.com/Bepely" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span class="footer-sep">&middot;</span>
        <a href="https://www.linkedin.com/in/nick-gogin/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
      <p class="footer-narr">Powered by <span class="narr-gradient">Narr</span></p>
      <p class="footer-copy">&copy; 2026 Bepely</p>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Oxygen, Ubuntu, Cantarell, "Fira Sans", "Droid Sans", "Helvetica Neue",
      sans-serif;
    line-height: 1.7;
    color: #f0ece4;
    background: #0a0a0a;
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #2a2518;
  }

  .site-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f0ece4;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .site-title:hover {
    color: #f5c542;
  }

  a {
    color: #f5c542;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    color: #e8752a;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    color: #f0ece4;
  }

  h2 {
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #f0ece4;
  }

  p {
    margin-bottom: 1rem;
  }

  blockquote {
    border-left: 3px solid #e8752a;
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: #a09880;
    font-style: italic;
  }

  main {
    min-height: 60vh;
  }

  article img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
    margin: 1.5rem 0;
    display: block;
  }

  .media-illustration {
    margin: 1.5rem 0;
  }
  .media-illustration img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }
  .media-location {
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    background: #1a1812;
    border-radius: 8px;
    display: inline-block;
    color: #a09880;
  }

  .site-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid #2a2518;
    text-align: center;
  }

  .footer-links {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: #f5c542;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: #e8752a;
  }

  .footer-sep {
    color: #2a2518;
    margin: 0 0.5rem;
  }

  .footer-narr {
    font-size: 0.75rem;
    color: #a09880;
    margin-bottom: 0.25rem;
  }

  .narr-gradient {
    font-weight: 700;
    background: linear-gradient(135deg, #f5c542, #e8752a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #a09880;
    margin-bottom: 0;
  }
</style>
