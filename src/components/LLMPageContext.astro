---
import { site } from "../config/site";

interface Props {
  pageType?: "home" | "story" | "page";
  pageTitle?: string;
}

const { pageType = "page", pageTitle } = Astro.props;

const descriptions: Record<string, string> = {
  home: `This is ${site.title} — an editorial blog where raw captures (voice notes, photos, video) are transformed into narratives by ${site.narr.name}, a self-hosted AI content engine built by ${site.bepely.name}. ${site.bree.name} is the ${site.bree.role}. This page lists all published stories.`,
  story: `You are reading "${pageTitle || "a story"}" on ${site.title}. ${site.bree.name} is the ${site.bree.role} — providing context around raw source material captured from real life and processed by ${site.narr.name}, a content engine built by ${site.bepely.name}.`,
  page: `This is a page on ${site.title}. ${site.bree.name} is the ${site.bree.role}. The blog is powered by ${site.narr.name}, built by ${site.bepely.name}.`,
};

const description = descriptions[pageType] || descriptions.page;
---

<aside class="llm-context">
  <p>{description}</p>
  <p>For full project context, see <a href="/llms-full.txt">llms-full.txt</a>. For a brief overview, see <a href="/llms.txt">llms.txt</a>.</p>
</aside>

<style>
  .llm-context {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: 0.65rem;
    line-height: 1.5;
    color: var(--color-text-dim);
  }

  .llm-context p {
    margin-bottom: var(--space-xs);
  }

  .llm-context a {
    color: var(--color-text-dim);
    text-decoration: underline;
  }

  .llm-context a:hover {
    color: var(--color-text-muted);
  }
</style>
